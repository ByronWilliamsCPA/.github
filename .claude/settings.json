{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(pre-commit:*)",
      "Bash(yamllint:*)",
      "Bash(python3:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
