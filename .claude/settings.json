{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh pr *)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh api repos/*/*)",
      "Bash(pre-commit:*)",
      "Bash(yamllint:*)",
      "Bash(python3 -m*)",
      "Bash(python3 *.py*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Bash(gh secret*)",
      "Bash(gh auth*)",
      "Bash(gh org*)",
      "Bash(gh workflow run*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo transfer*)",
      "Bash(gh repo rename*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)",
      "Bash(gh api -X DELETE*)",
      "Bash(gh api --method DELETE*)",
      "Bash(gh api -X PATCH*)",
      "Bash(gh api --method PATCH*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)"
    ]
  }
}
